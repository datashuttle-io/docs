<!-- v3 fonts, loaded as a parallel stylesheet so they never block first paint.
     (A remote @import in brand-v6.css was render-blocking + serial — it stalled
     the docs for ~1.4s on load.) display=swap shows fallback text immediately. -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500&display=swap">
